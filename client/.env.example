# =============================================================================
# Hyperindex Client Configuration
# =============================================================================

# Public/client-facing Hyperindex URL (baked into the JS bundle at build time)
# For local development: http://localhost:8080
# For production: https://your-railway-app.up.railway.app
NEXT_PUBLIC_HYPERINDEX_URL=http://localhost:8080

# Server-side only — use this for private/internal network endpoints (e.g. Railway private networking).
# Falls back to NEXT_PUBLIC_HYPERINDEX_URL so you only need one var if both URLs are the same.
HYPERINDEX_URL=http://127.0.0.1:8080

# =============================================================================
# OAuth Configuration
# =============================================================================

# Public URL of this client (required for production OAuth)
# Canonical variable used by the app:
#   NEXT_PUBLIC_CLIENT_URL -> NEXT_PUBLIC_VERCEL_BRANCH_URL
# Leave empty for local development (uses http://127.0.0.1:3000)
NEXT_PUBLIC_CLIENT_URL=

# Optional Vercel branch URL fallback (used only if above are empty)
# If set to a host only (e.g. "my-branch.vercel.app"), the app will prepend https://
# If it already includes http:// or https://, it is used as-is.
NEXT_PUBLIC_VERCEL_BRANCH_URL=

# Secret for encrypting session cookies (must be at least 32 characters)
# Generate with: openssl rand -base64 32
COOKIE_SECRET=development-secret-at-least-32-chars!!

# Private JWK for confidential OAuth client (optional)
# For production, you can generate a key pair with:
#   npm run gen-keys
# Then paste the private key JSON here (minified, single line)
# Leave empty to use public client mode (simpler, works for most cases)
ATPROTO_JWK_PRIVATE=
